---
const year = new Date().getFullYear()
---

<footer class="bg-navy border-t border-white/6">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <div>
        <p class="font-heading font-bold text-gold text-lg tracking-tight">WisWealthy</p>
        <p class="text-[10px] text-ivory/30 tracking-widest uppercase mt-1">Wealth Through Wisdom</p>
        <p class="text-xs mt-5 leading-relaxed text-ivory/35">
          SEBI Registered Investment Adviser<br />
          Registration No: [Placeholder]<br />
          CIN: [Placeholder]
        </p>
      </div>

      <div>
        <p class="text-ivory/70 text-xs font-semibold tracking-widest uppercase mb-4">Navigate</p>
        <ul class="space-y-2.5 text-sm">
          {[
            ["About", "/about"],
            ["Portfolio Solutions", "/services"],
            ["Philosophy", "/philosophy"],
            ["Downloads", "/downloads"],
            ["Contact", "/contact"],
          ].map(([label, href]) => (
            <li><a href={href} class="text-ivory/55 hover:text-gold transition-colors text-sm">{label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-ivory/70 text-xs font-semibold tracking-widest uppercase mb-4">Get in Touch</p>
        <p class="text-ivory/55 text-sm">hello@wiswealthy.com</p>
        <p class="text-ivory/55 text-sm mt-1">+91 [Phone Placeholder]</p>
        <a href="/contact"
           class="inline-block mt-5 border border-white/12 text-gold text-xs font-medium px-5 py-2 rounded-full hover:border-gold/40 transition-colors">
          Book a Discovery Call
        </a>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/6 text-[11px] text-ivory/25 flex flex-col sm:flex-row justify-between gap-3">
      <p>&copy; {year} WisWealthy. All rights reserved.</p>
      <p>For informational purposes only. Not an offer to buy or sell securities.</p>
    </div>
  </div>
</footer>
