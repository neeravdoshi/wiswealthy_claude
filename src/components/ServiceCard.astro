---
import { DynamicIcon } from "@/components/DynamicIcon"

interface Props {
  title: string
  description: string
  icon: string
  slug: string
}

const { title, description, icon, slug } = Astro.props
---

<a
  href={`/services/${slug}`}
  class="group block rounded-2xl border border-white/8 bg-charcoal p-7 transition-all duration-300 hover:-translate-y-1 hover:border-gold/30 hover:glow-card"
>
  <div class="w-11 h-11 rounded-xl bg-gold/10 border border-gold/20 flex items-center justify-center mb-5">
    <DynamicIcon client:load name={icon} size={20} className="text-gold" />
  </div>
  <h3 class="font-heading font-bold text-base text-ivory mb-2.5 tracking-tight group-hover:text-gold transition-colors">
    {title}
  </h3>
  <p class="text-sm text-ivory/65 leading-relaxed mb-5">
    {description}
  </p>
  <span class="inline-flex items-center gap-1.5 text-xs text-gold/70 font-medium group-hover:text-gold group-hover:gap-2.5 transition-all">
    Learn more
    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
    </svg>
  </span>
</a>
