---
import Layout from "@/layouts/main.astro"
import { getCollection, render } from "astro:content"

const entries = await getCollection("journey")
const entry = entries[0]!
const { Content } = await render(entry)
---

<Layout title="About WisWealthy | Our Journey" description="Learn about WisWealthy's history and our fiduciary-first approach to portfolio advisory.">

  <!-- Hero -->
  <section class="glow-hero py-28 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <div class="badge-pill mb-8">The Journey</div>
      <h1 class="font-heading font-bold text-ivory leading-tight tracking-tight mb-4"
          style="font-size: clamp(2rem, 5vw, 3.5rem);">
        {entry.data.title}
      </h1>
      <p class="text-ivory/65 text-base">{entry.data.subtitle}</p>
    </div>
  </section>

  <!-- Story -->
  <section class="bg-background border-t border-white/6 py-20 px-6">
    <div class="max-w-2xl mx-auto">
      <article class="prose max-w-none
        [&_p]:text-ivory/70 [&_p]:text-base [&_p]:leading-relaxed [&_p]:mb-4">
        <Content />
      </article>
    </div>
  </section>

  <!-- Timeline -->
  <section class="bg-navy border-y border-white/6 py-20 px-6">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-heading font-bold text-ivory text-base tracking-tight mb-10">Key Milestones</h2>
      <ol class="space-y-8">
        {entry.data.milestones.map(m => (
          <li class="flex gap-8 items-baseline py-6 border-b border-white/8 last:border-0">
            <span class="font-heading font-bold text-gold text-sm tracking-widest shrink-0 w-12 uppercase">{m.year}</span>
            <p class="text-ivory/70 text-base leading-relaxed">{m.event}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 text-center bg-background">
    <p class="text-ivory/60 text-base mb-6">The next chapter of your journey starts with a conversation.</p>
    <a href="/contact"
       class="inline-block bg-gold text-navy font-semibold px-8 py-3.5 rounded-full hover:bg-gold/90 transition-colors text-sm">
      Book a Discovery Call
    </a>
  </section>

</Layout>
